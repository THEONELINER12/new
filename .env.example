# Leave blank to write scheduled summaries to logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SUMMARY_TO_EMAILS=
SMTP_USE_TLS=true

